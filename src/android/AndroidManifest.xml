<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.coraldrift.jumpinggame">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:label="Coral Drift"
        android:hardwareAccelerated="true"
        android:allowBackup="false">

        <activity android:name="com.gluonhq.helloandroid.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|smallestScreenSize|uiMode|navigation|keyboard"
                  android:screenOrientation="sensorLandscape"
                  android:launchMode="singleTask"
                  android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
            <meta-data android:name="main.class" android:value="com.coraldrift.MainApp"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
