<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.coraldrift.jumpinggame"
    android:versionCode="2"
    android:versionName="1.1">

    <!-- Tested up to Android 15 (Galaxy S25). minSdk 24 = Android 7.0 -->
    <uses-sdk android:minSdkVersion="24" android:targetSdkVersion="34"/>

    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Declare full hardware-accel + landscape touchscreen so the Play
         Store and modern launchers correctly identify the app as a game -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true"/>
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true"/>

    <application
        android:label="Coral Drift"
        android:hardwareAccelerated="true"
        android:allowBackup="false"
        android:isGame="true"
        android:appCategory="game"
        android:resizeableActivity="false"
        android:requestLegacyExternalStorage="false">

        <activity android:name="com.gluonhq.helloandroid.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|smallestScreenSize|uiMode|navigation|keyboard|density|fontScale|locale|mcc|mnc|touchscreen"
                  android:screenOrientation="sensorLandscape"
                  android:launchMode="singleTask"
                  android:resizeableActivity="false"
                  android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
            <meta-data android:name="main.class" android:value="com.coraldrift.MainApp"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
